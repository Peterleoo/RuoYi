<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.portal.mapper.PortalActivityMapper">

    <resultMap id="PortalActivityResult" type="com.ruoyi.portal.domain.PortalActivity">
        <id property="activityId" column="activity_id"/>
        <result property="schoolId" column="school_id"/>
        <result property="activityName" column="activity_name"/>
        <result property="category" column="category"/>
        <result property="coverImage" column="cover_image"/>
        <result property="activityContent" column="activity_content"/>
        <result property="startTime" column="start_time"/>
        <result property="endTime" column="end_time"/>
        <result property="registrationDeadline" column="registration_deadline"/>
        <result property="location" column="location"/>
        <result property="capacity" column="capacity"/>
        <result property="currentRegistrations" column="current_registrations"/>
        <result property="activityStatus" column="activity_status"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
        <result property="schoolName" column="school_name"/>
    </resultMap>

    <sql id="selectPortalActivityVo">
        select a.activity_id, a.school_id, a.activity_name, a.category, a.cover_image, a.activity_content,
               a.start_time, a.end_time, a.registration_deadline, a.location, a.capacity, a.current_registrations,
               a.activity_status, a.status, a.create_by, a.create_time, a.update_by, a.update_time, a.remark,
               s.school_name
        from portal_activity a
        left join portal_school s on a.school_id = s.school_id
    </sql>

    <select id="selectPortalActivityById" parameterType="Long" resultMap="PortalActivityResult">
        <include refid="selectPortalActivityVo"/>
        where a.activity_id = #{activityId}
    </select>

    <select id="selectPortalActivityList" parameterType="com.ruoyi.portal.domain.PortalActivity" resultMap="PortalActivityResult">
        <include refid="selectPortalActivityVo"/>
        <where>
            <if test="schoolId != null">
                and a.school_id = #{schoolId}
            </if>
            <if test="activityName != null and activityName != ''">
                and a.activity_name like concat('%', #{activityName}, '%')
            </if>
            <if test="category != null and category != ''">
                and a.category = #{category}
            </if>
            <if test="activityStatus != null and activityStatus != ''">
                and a.activity_status = #{activityStatus}
            </if>
            <if test="status != null and status != ''">
                and a.status = #{status}
            </if>
        </where>
        order by a.activity_id desc
    </select>

    <insert id="insertPortalActivity" parameterType="com.ruoyi.portal.domain.PortalActivity" useGeneratedKeys="true" keyProperty="activityId">
        insert into portal_activity
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="schoolId != null">school_id,</if>
            <if test="activityName != null">activity_name,</if>
            <if test="category != null">category,</if>
            <if test="coverImage != null">cover_image,</if>
            <if test="activityContent != null">activity_content,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="registrationDeadline != null">registration_deadline,</if>
            <if test="location != null">location,</if>
            <if test="capacity != null">capacity,</if>
            <if test="currentRegistrations != null">current_registrations,</if>
            <if test="activityStatus != null">activity_status,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="schoolId != null">#{schoolId},</if>
            <if test="activityName != null">#{activityName},</if>
            <if test="category != null">#{category},</if>
            <if test="coverImage != null">#{coverImage},</if>
            <if test="activityContent != null">#{activityContent},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="registrationDeadline != null">#{registrationDeadline},</if>
            <if test="location != null">#{location},</if>
            <if test="capacity != null">#{capacity},</if>
            <if test="currentRegistrations != null">#{currentRegistrations},</if>
            <if test="activityStatus != null">#{activityStatus},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updatePortalActivity" parameterType="com.ruoyi.portal.domain.PortalActivity">
        update portal_activity
        <set>
            <if test="schoolId != null">school_id = #{schoolId},</if>
            <if test="activityName != null">activity_name = #{activityName},</if>
            <if test="category != null">category = #{category},</if>
            <if test="coverImage != null">cover_image = #{coverImage},</if>
            <if test="activityContent != null">activity_content = #{activityContent},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="registrationDeadline != null">registration_deadline = #{registrationDeadline},</if>
            <if test="location != null">location = #{location},</if>
            <if test="capacity != null">capacity = #{capacity},</if>
            <if test="currentRegistrations != null">current_registrations = #{currentRegistrations},</if>
            <if test="activityStatus != null">activity_status = #{activityStatus},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where activity_id = #{activityId}
    </update>

    <delete id="deletePortalActivityById" parameterType="Long">
        delete from portal_activity where activity_id = #{activityId}
    </delete>

    <delete id="deletePortalActivityByIds" parameterType="Long[]">
        delete from portal_activity where activity_id in
        <foreach item="activityId" collection="array" open="(" separator="," close=")">
            #{activityId}
        </foreach>
    </delete>
</mapper>
