<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.portal.mapper.PortalCourseMapper">

    <resultMap id="PortalCourseResult" type="com.ruoyi.portal.domain.PortalCourse">
        <id property="courseId" column="course_id"/>
        <result property="schoolId" column="school_id"/>
        <result property="courseName" column="course_name"/>
        <result property="courseCategory" column="course_category"/>
        <result property="teacherId" column="teacher_id"/>
        <result property="coverImage" column="cover_image"/>
        <result property="courseIntro" column="course_intro"/>
        <result property="classSchedule" column="class_schedule"/>
        <result property="replayVideoUrl" column="replay_video_url"/>
        <result property="tuitionFee" column="tuition_fee"/>
        <result property="enrollmentStatus" column="enrollment_status"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
        <result property="schoolName" column="school_name"/>
        <result property="teacherName" column="teacher_name"/>
    </resultMap>

    <sql id="selectPortalCourseVo">
        select c.course_id, c.school_id, c.course_name, c.course_category, c.teacher_id,
               c.cover_image, c.course_intro, c.class_schedule, c.replay_video_url,
               c.tuition_fee, c.enrollment_status, c.status, c.create_by, c.create_time,
               c.update_by, c.update_time, c.remark,
               s.school_name, t.teacher_name
        from portal_course c
        left join portal_school s on c.school_id = s.school_id
        left join portal_teacher t on c.teacher_id = t.teacher_id
    </sql>

    <select id="selectPortalCourseById" parameterType="Long" resultMap="PortalCourseResult">
        <include refid="selectPortalCourseVo"/>
        where c.course_id = #{courseId}
    </select>

    <select id="selectPortalCourseList" parameterType="com.ruoyi.portal.domain.PortalCourse" resultMap="PortalCourseResult">
        <include refid="selectPortalCourseVo"/>
        <where>
            <if test="schoolId != null">
                and c.school_id = #{schoolId}
            </if>
            <if test="teacherId != null">
                and c.teacher_id = #{teacherId}
            </if>
            <if test="courseName != null and courseName != ''">
                and c.course_name like concat('%', #{courseName}, '%')
            </if>
            <if test="courseCategory != null and courseCategory != ''">
                and c.course_category = #{courseCategory}
            </if>
            <if test="status != null and status != ''">
                and c.status = #{status}
            </if>
        </where>
        order by c.course_id desc
    </select>

    <select id="selectPortalCourseBySchoolId" parameterType="Long" resultMap="PortalCourseResult">
        <include refid="selectPortalCourseVo"/>
        where c.school_id = #{schoolId}
        order by c.course_id desc
    </select>

    <insert id="insertPortalCourse" parameterType="com.ruoyi.portal.domain.PortalCourse" useGeneratedKeys="true" keyProperty="courseId">
        insert into portal_course
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="schoolId != null">school_id,</if>
            <if test="courseName != null">course_name,</if>
            <if test="courseCategory != null">course_category,</if>
            <if test="teacherId != null">teacher_id,</if>
            <if test="coverImage != null">cover_image,</if>
            <if test="courseIntro != null">course_intro,</if>
            <if test="classSchedule != null">class_schedule,</if>
            <if test="replayVideoUrl != null">replay_video_url,</if>
            <if test="tuitionFee != null">tuition_fee,</if>
            <if test="enrollmentStatus != null">enrollment_status,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="schoolId != null">#{schoolId},</if>
            <if test="courseName != null">#{courseName},</if>
            <if test="courseCategory != null">#{courseCategory},</if>
            <if test="teacherId != null">#{teacherId},</if>
            <if test="coverImage != null">#{coverImage},</if>
            <if test="courseIntro != null">#{courseIntro},</if>
            <if test="classSchedule != null">#{classSchedule},</if>
            <if test="replayVideoUrl != null">#{replayVideoUrl},</if>
            <if test="tuitionFee != null">#{tuitionFee},</if>
            <if test="enrollmentStatus != null">#{enrollmentStatus},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updatePortalCourse" parameterType="com.ruoyi.portal.domain.PortalCourse">
        update portal_course
        <set>
            <if test="schoolId != null">school_id = #{schoolId},</if>
            <if test="courseName != null">course_name = #{courseName},</if>
            <if test="courseCategory != null">course_category = #{courseCategory},</if>
            <if test="teacherId != null">teacher_id = #{teacherId},</if>
            <if test="coverImage != null">cover_image = #{coverImage},</if>
            <if test="courseIntro != null">course_intro = #{courseIntro},</if>
            <if test="classSchedule != null">class_schedule = #{classSchedule},</if>
            <if test="replayVideoUrl != null">replay_video_url = #{replayVideoUrl},</if>
            <if test="tuitionFee != null">tuition_fee = #{tuitionFee},</if>
            <if test="enrollmentStatus != null">enrollment_status = #{enrollmentStatus},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where course_id = #{courseId}
    </update>

    <delete id="deletePortalCourseById" parameterType="Long">
        delete from portal_course where course_id = #{courseId}
    </delete>

    <delete id="deletePortalCourseByIds" parameterType="Long[]">
        delete from portal_course where course_id in
        <foreach item="courseId" collection="array" open="(" separator="," close=")">
            #{courseId}
        </foreach>
    </delete>

</mapper>
