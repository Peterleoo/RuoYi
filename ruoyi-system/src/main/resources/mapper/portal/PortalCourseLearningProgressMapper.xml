<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.portal.mapper.PortalCourseLearningProgressMapper">

    <resultMap id="PortalCourseLearningProgressResult" type="com.ruoyi.portal.domain.PortalCourseLearningProgress">
        <id property="progressId" column="progress_id"/>
        <result property="memberId" column="member_id"/>
        <result property="courseId" column="course_id"/>
        <result property="progressPercent" column="progress_percent"/>
        <result property="progressStatus" column="progress_status"/>
        <result property="studyMinutes" column="study_minutes"/>
        <result property="lastStudyTime" column="last_study_time"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
        <result property="courseName" column="course_name"/>
        <result property="courseCategory" column="course_category"/>
        <result property="replayVideoUrl" column="replay_video_url"/>
    </resultMap>

    <sql id="selectPortalCourseLearningProgressVo">
        select p.progress_id, p.member_id, p.course_id, p.progress_percent, p.progress_status, p.study_minutes,
               p.last_study_time, p.create_by, p.create_time, p.update_by, p.update_time, p.remark,
               c.course_name, c.course_category, c.replay_video_url
        from portal_course_learning_progress p
        left join portal_course c on p.course_id = c.course_id
    </sql>

    <select id="selectByMemberAndCourse" resultMap="PortalCourseLearningProgressResult">
        <include refid="selectPortalCourseLearningProgressVo"/>
        where p.member_id = #{memberId} and p.course_id = #{courseId}
        limit 1
    </select>

    <select id="selectByMemberId" parameterType="Long" resultMap="PortalCourseLearningProgressResult">
        <include refid="selectPortalCourseLearningProgressVo"/>
        where p.member_id = #{memberId}
        order by p.last_study_time desc, p.progress_id desc
    </select>

    <insert id="insertPortalCourseLearningProgress" parameterType="com.ruoyi.portal.domain.PortalCourseLearningProgress" useGeneratedKeys="true" keyProperty="progressId">
        insert into portal_course_learning_progress
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="memberId != null">member_id,</if>
            <if test="courseId != null">course_id,</if>
            <if test="progressPercent != null">progress_percent,</if>
            <if test="progressStatus != null">progress_status,</if>
            <if test="studyMinutes != null">study_minutes,</if>
            <if test="lastStudyTime != null">last_study_time,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="memberId != null">#{memberId},</if>
            <if test="courseId != null">#{courseId},</if>
            <if test="progressPercent != null">#{progressPercent},</if>
            <if test="progressStatus != null">#{progressStatus},</if>
            <if test="studyMinutes != null">#{studyMinutes},</if>
            <if test="lastStudyTime != null">#{lastStudyTime},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updatePortalCourseLearningProgress" parameterType="com.ruoyi.portal.domain.PortalCourseLearningProgress">
        update portal_course_learning_progress
        <set>
            <if test="progressPercent != null">progress_percent = #{progressPercent},</if>
            <if test="progressStatus != null">progress_status = #{progressStatus},</if>
            <if test="studyMinutes != null">study_minutes = #{studyMinutes},</if>
            <if test="lastStudyTime != null">last_study_time = #{lastStudyTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where progress_id = #{progressId}
    </update>

</mapper>
