<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.portal.mapper.PortalContentCategoryMapper">

    <resultMap id="PortalContentCategoryResult" type="com.ruoyi.portal.domain.PortalContentCategory">
        <id property="categoryId" column="category_id"/>
        <result property="categoryName" column="category_name"/>
        <result property="sortNum" column="sort_num"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectPortalContentCategoryVo">
        select category_id, category_name, sort_num, status, create_by, create_time, update_by, update_time, remark
        from portal_content_category
    </sql>

    <select id="selectPortalContentCategoryById" parameterType="Long" resultMap="PortalContentCategoryResult">
        <include refid="selectPortalContentCategoryVo"/>
        where category_id = #{categoryId}
    </select>

    <select id="selectPortalContentCategoryList" parameterType="com.ruoyi.portal.domain.PortalContentCategory" resultMap="PortalContentCategoryResult">
        <include refid="selectPortalContentCategoryVo"/>
        <where>
            <if test="categoryName != null and categoryName != ''">
                and category_name like concat('%', #{categoryName}, '%')
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by sort_num asc, category_id desc
    </select>

    <insert id="insertPortalContentCategory" parameterType="com.ruoyi.portal.domain.PortalContentCategory" useGeneratedKeys="true" keyProperty="categoryId">
        insert into portal_content_category
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="categoryName != null">category_name,</if>
            <if test="sortNum != null">sort_num,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="categoryName != null">#{categoryName},</if>
            <if test="sortNum != null">#{sortNum},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updatePortalContentCategory" parameterType="com.ruoyi.portal.domain.PortalContentCategory">
        update portal_content_category
        <set>
            <if test="categoryName != null">category_name = #{categoryName},</if>
            <if test="sortNum != null">sort_num = #{sortNum},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where category_id = #{categoryId}
    </update>

    <delete id="deletePortalContentCategoryById" parameterType="Long">
        delete from portal_content_category where category_id = #{categoryId}
    </delete>

    <delete id="deletePortalContentCategoryByIds" parameterType="Long[]">
        delete from portal_content_category where category_id in
        <foreach item="categoryId" collection="array" open="(" separator="," close=")">
            #{categoryId}
        </foreach>
    </delete>

</mapper>

