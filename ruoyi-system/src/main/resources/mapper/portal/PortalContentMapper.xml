<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.portal.mapper.PortalContentMapper">
    <resultMap type="com.ruoyi.portal.domain.PortalContent" id="PortalContentResult">
        <id     property="contentId"    column="content_id"    />
        <result property="title"        column="title"        />
        <result property="content"      column="content"      />
        <result property="summary"      column="summary"      />
        <result property="coverImage"   column="cover_image"  />
        <result property="category"     column="category"     />
        <result property="author"       column="author"       />
        <result property="viewCount"    column="view_count"   />
        <result property="status"       column="status"       />
        <result property="createBy"     column="create_by"    />
        <result property="createTime"   column="create_time"  />
        <result property="updateBy"     column="update_by"    />
        <result property="updateTime"   column="update_time"  />
        <result property="remark"       column="remark"       />
    </resultMap>

    <sql id="selectPortalContentVo">
        select content_id, title, content, summary, cover_image, category, author, view_count, status, create_by, create_time, update_by, update_time, remark
        from portal_content
    </sql>

    <select id="selectPortalContentList" parameterType="com.ruoyi.portal.domain.PortalContent" resultMap="PortalContentResult">
        <include refid="selectPortalContentVo" />
        <where>
            <if test="title != null and title != ''">
                AND title like concat('%', #{title}, '%')
            </if>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectPortalContentById" parameterType="Long" resultMap="PortalContentResult">
        <include refid="selectPortalContentVo" />
        where content_id = #{contentId}
    </select>

    <insert id="insertPortalContent" parameterType="com.ruoyi.portal.domain.PortalContent" useGeneratedKeys="true" keyProperty="contentId">
        insert into portal_content
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null">title,</if>
            <if test="content != null">content,</if>
            <if test="summary != null">summary,</if>
            <if test="coverImage != null">cover_image,</if>
            <if test="category != null">category,</if>
            <if test="author != null">author,</if>
            <if test="viewCount != null">view_count,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null">#{title},</if>
            <if test="content != null">#{content},</if>
            <if test="summary != null">#{summary},</if>
            <if test="coverImage != null">#{coverImage},</if>
            <if test="category != null">#{category},</if>
            <if test="author != null">#{author},</if>
            <if test="viewCount != null">#{viewCount},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updatePortalContent" parameterType="com.ruoyi.portal.domain.PortalContent">
        update portal_content
        <set>
            <if test="title != null">title = #{title},</if>
            <if test="content != null">content = #{content},</if>
            <if test="summary != null">summary = #{summary},</if>
            <if test="coverImage != null">cover_image = #{coverImage},</if>
            <if test="category != null">category = #{category},</if>
            <if test="author != null">author = #{author},</if>
            <if test="viewCount != null">view_count = #{viewCount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where content_id = #{contentId}
    </update>

    <delete id="deletePortalContentById" parameterType="Long">
        delete from portal_content where content_id = #{contentId}
    </delete>
</mapper>